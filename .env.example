# Copy this file to .env and fill in real values.
# Docker Compose service hostnames are used as defaults (mongo, postgres, redpanda).
# For local development without Docker, change hostnames to localhost.

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=voice_raw

# PostgreSQL
POSTGRES_DSN=postgresql://voice:voice@postgres:5432/voice

# Kafka / Redpanda
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_KEYWORD=voice-keyword-queue
KAFKA_PROJECT_VERSION=0.1

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Monitoring
# Set to true to show Detail Crawling and Comment Fetching in separate panels.
# Default false = single unified panel.
LOG_SPLIT=true