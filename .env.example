# Copy this file to .env and fill in real values.
# Docker Compose service hostnames are used as defaults (mongo, postgres, redpanda).
# For local development without Docker, change hostnames to localhost.

# MongoDB
# From host (dev): mongodb://voice:voice@localhost:27017/?authSource=admin
# From inside Docker: mongodb://voice:voice@mongodb:27017/?authSource=admin
MONGO_URI=mongodb://voice:voice@localhost:27017/?authSource=admin
MONGO_DB=voice
MONGO_COLLECTION=bronze

# PostgreSQL
# From host (dev): postgresql://voice:voice@localhost:5432/voice_warehouse
# From inside Docker: postgresql://voice:voice@postgres:5432/voice_warehouse
POSTGRES_DSN=postgresql://voice:voice@localhost:5432/voice_warehouse

# Message Broker
# BROKER_TYPE: "redpanda" (default, ringan, cocok dev/laptop)
#              "kafka"    (alternatif, production-grade, ekosistem lebih lengkap)
#
# Run Redpanda: docker compose --profile redpanda up -d  → broker di localhost:19092
# Run Kafka:    docker compose --profile kafka up -d     → broker di localhost:9092
BROKER_TYPE=redpanda
REDPANDA_BROKER=localhost:19092
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_KEYWORD=voice-keyword-queue
KAFKA_PROJECT_VERSION=0.1

# Valkey
# From host (dev): redis://localhost:6379/0
# From inside Docker: redis://voice-valkey:6379/0
VALKEY_URL=redis://localhost:6379/0

# Piped — YouTube data source (local Docker, profile: piped)
# Jalankan: docker compose --profile piped up -d
# Dari host: http://localhost:8888
PIPED_BASE_URL=http://localhost:8888

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Scraper
# SCRAPER_DELAY : detik antar HTTP request (rate limiting). Default 1.0.
#                 News sites aman di 0.5, Reddit butuh minimal 1.0.
# SCRAPER_LIMIT : max content per source per job. 0 = unlimited. Default 50.
# PROXY_URL     : opsional. Kosongkan jika tidak pakai proxy.
#                 Format: http://user:pass@host:port
SCRAPER_DELAY=1.0
SCRAPER_LIMIT=50
PROXY_URL=

# Monitoring
# Set to true to show Detail Crawling and Comment Fetching in separate panels.
# Default false = single unified panel.
LOG_SPLIT=true